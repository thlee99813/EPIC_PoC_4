  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "1. \uB4DC\uB798\uD504\uD2B8\uB85C \uAE30\uD638 \uCE74\uB4DC\uC640 \uC22B\uC790
    \uCE74\uB4DC\uB97C \uACE8\uB77C \uC22B\uC790\uB97C \uB354\uD569\uB2C8\uB2E4.\n\uCD1D
    4\uC7A5\uC758 \uCE74\uB4DC\uB97C \uBF51\uB294\uAC8C \uD55C\uBC88\uC758 \uB4DC\uB798\uD504\uD2B8\uC785\uB2C8\uB2E4.\n\r\n2.
    \uC67C\uC190\uC740 \uC22B\uC790\uAC00 \uB0AE\uC744\uC218\uB85D \uAC15\uD558\uACE0,
    \uC624\uB978\uC190\uC740 \uC22B\uC790\uAC00 \uB192\uC744\uC218\uB85D \uAC15\uD569\uB2C8\uB2E4.\n\r\n3.
    \uD55C \uC190\uC5D0\uB294 6\uD68C\uC758 \uC5F0\uC0B0 \uC911 4\uD68C \uB9CC \uC5F0\uC0B0\uC744
    \uC801\uC6A9\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n\r\n4. \uB4DC\uB798\uD504\uD2B8\uAC00
    3\uD68C \uB05D\uB098\uBA74 \uC88C\uACF5\uACA9, \uC6B0\uACF5\uACA9, \uC591\uC190\uACF5\uACA9
    \uC911 \uD558\uB098\uB97C \uC120\uD0DD\uD569\uB2C8\uB2E4.\r\n\r\n5. \uC591\uC190\uACF5\uACA9\uC740
    \uC67C\uC190\uACFC \uC624\uB978\uC190\uC744 \uBAA8\uB450 \uC774\uACA8\uC57C \uC131\uACF5\uD569\uB2C8\uB2E4.\n\r\n6.
    \uC11C\uB85C \uB2E4\uB978 \uB2E8\uC77C \uC190\uC744 \uB0B4\uBA74 \uC804\uD22C\uAC00
    \uC77C\uC5B4\uB098\uC9C0 \uC54A\uACE0 \uAE34\uC7A5\uB3C4\uAC00 \uC624\uB985\uB2C8\uB2E4.\n\r\n7.
    \uAE34\uC7A5\uB3C4\uAC00 \uB192\uC744\uC218\uB85D \uB2E4\uC74C \uC804\uD22C \uD53C\uD574\uB7C9\uC774
    \uC99D\uAC00\uD569\uB2C8\uB2E4."
